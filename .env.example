# API keys
OPENAI_API_KEY=change-me-openai-api-key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REPORT_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=
LANGSMITH_WORKSPACE_ID=

# Local development via kubectl port-forward:
# kubectl port-forward svc/team5-postgres 5433:5432 -n skala3-finalproj-class2-team5
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=safety
SERVICE_APP_USER=safety_service_app
SERVICE_APP_PASSWORD=change-me-service-app-password

# Qdrant local or port-forward:
# kubectl port-forward svc/team5-qdrant 6333:6333 -n skala3-finalproj-class2-team5
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OCR 엔진 선택 (vlm | clova)
OCR_ENGINE=vlm

# VLM — Gemini (OCR_ENGINE=vlm, VLM_PROVIDER=gemini 시 사용)
VLM_PROVIDER=gemini
GEMINI_API_KEY=change-me-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# VLM — OpenAI (VLM_PROVIDER=openai 로 전환 시 사용)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL_FALLBACK=gpt-4o

# CLOVA OCR (OCR_ENGINE=clova 시 사용)
CLOVA_OCR_SECRET=change-me-clova-ocr-secret
CLOVA_OCR_URL=change-me-clova-ocr-url

# S3/MinIO
AWS_REGION=ap-northeast-2
APP_MINIO_ENDPOINT=http://localhost:9000
APP_MINIO_BUCKET=safety-files
APP_MINIO_ACCESS_KEY=minioadmin
APP_MINIO_SECRET_KEY=minioadmin
# Use a Docker-network URL when another container, such as vision, consumes presigned URLs.
S3_PUBLIC_ENDPOINT_URL=http://minio:9000
APP_MINIO_PUBLIC_ENDPOINT=http://minio:9000
S3_PRESIGNED_URL_EXPIRE_SECONDS=900

# Matching thresholds
THRESHOLD_MATCHED=0.85
THRESHOLD_REVIEW=0.75

# External Vision Agent
VISION_AGENT_BASE_URL=http://localhost:8002
VISION_AGENT_REVIEW_PATH=/vision/review
VISION_AGENT_TIMEOUT_SECONDS=60
