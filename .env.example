# API keys
OPENAI_API_KEY=change-me-openai-api-key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AI usage cost fallback / override, USD per 1M tokens.
# Known model prices are handled in code. Use these only for unknown models or team-specific aliases.
AGENT_USAGE_DEFAULT_INPUT_USD_PER_1M_TOKENS=0.40
AGENT_USAGE_DEFAULT_CACHED_INPUT_USD_PER_1M_TOKENS=0.10
AGENT_USAGE_DEFAULT_OUTPUT_USD_PER_1M_TOKENS=1.60
# Example: AGENT_USAGE_INPUT_USD_PER_1M_TOKENS_GPT_4_1_MINI=0.40
# Example: AGENT_USAGE_CACHED_INPUT_USD_PER_1M_TOKENS_GPT_4_1_MINI=0.10
# Example: AGENT_USAGE_OUTPUT_USD_PER_1M_TOKENS_GPT_4_1_MINI=1.60

LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=
LANGSMITH_WORKSPACE_ID=

TAVILY_API_KEY=

# Local development via kubectl port-forward:
# kubectl port-forward svc/team5-postgres 5433:5432 -n skala3-finalproj-class2-team5
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=safety
SERVICE_APP_USER=safety_service_app
SERVICE_APP_PASSWORD=change-me-service-app-password

# Qdrant local or port-forward:
# kubectl port-forward svc/team5-qdrant 6333:6333 -n skala3-finalproj-class2-team5
QDRANT_URL=http://localhost:6333
SAFETY_DOC_QDRANT_URL=http://localhost:6333

# OCR 엔진 선택 (clova | vlm, 기본값: vlm)
OCR_ENGINE=vlm

# CLOVA OCR (OCR_ENGINE=clova 시 사용)
CLOVA_OCR_SECRET=change-me-clova-ocr-secret
CLOVA_OCR_URL=change-me-clova-ocr-url

# VLM OCR (OCR_ENGINE=vlm 시 사용)
# Gemini (VLM_PROVIDER=gemini, 기본값)
VLM_PROVIDER=gemini
GEMINI_API_KEY=change-me-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
# OpenAI (VLM_PROVIDER=openai 로 전환 시 사용)
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-4o
