# API keys
OPENAI_API_KEY=change-me-openai-api-key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=
LANGSMITH_WORKSPACE_ID=

TAVILY_API_KEY=

# Local development via kubectl port-forward:
# kubectl port-forward svc/team5-postgres 5433:5432 -n skala3-finalproj-class2-team5
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=safety
SERVICE_APP_USER=safety_service_app
SERVICE_APP_PASSWORD=change-me-service-app-password

# Qdrant local or port-forward:
# kubectl port-forward svc/team5-qdrant 6333:6333 -n skala3-finalproj-class2-team5
QDRANT_URL=http://localhost:6333
SAFETY_DOC_QDRANT_URL=http://localhost:6333

# OCR, when needed
CLOVA_OCR_SECRET=change-me-clova-ocr-secret
CLOVA_OCR_URL=change-me-clova-ocr-url
