{
  "layout_version": "safety_cost_report_v1",
  "description": "산업안전보건관리비 증빙 검토 결과 보고서 구조 기반 JSON 템플릿입니다. 웹 렌더링과 DOCX 추출은 이 섹션/표 구조를 기준으로 합니다.",
  "sections": [
    {
      "section_id": "cover",
      "title": "{{draft.title}}",
      "kind": "cover",
      "tables": [
        {
          "rows": [
            ["현장명", "{{draft.site_name}}"],
            ["검토 대상 기간", "{{draft.report_period_label}}"],
            ["보고서 번호", "{{draft.report_no}}"],
            ["작성일", "{{draft.written_date_label}}"],
            ["작성 부서", "{{draft.department_full_label}}"]
          ]
        }
      ]
    },
    {
      "section_id": "basic_info",
      "title": "1. 기본 정보",
      "kind": "table",
      "tables": [
        {
          "rows": [
            ["보고서 번호", "{{draft.report_no}}", "검토 일자", "{{draft.written_date_label}}"],
            ["현장명", "{{draft.site_name}}", "프로젝트 번호", "{{draft.basic_info.프로젝트 번호}}"],
            ["발주처", "{{draft.basic_info.발주처}}", "시공사", "{{draft.basic_info.시공사}}"],
            ["계약금액", "{{draft.basic_info.계약금액}}", "공사기간", "{{draft.basic_info.공사기간}}"],
            ["법정 계상액", "{{draft.basic_info.법정 계상액}}", "검토자", "{{draft.reviewer_label}}"],
            ["검토 대상 기간", "{{draft.report_period_label}}", "검토 목적", "{{draft.basic_info.검토 목적}}"]
          ]
        }
      ]
    },
    {
      "section_id": "execution_summary",
      "title": "2. 집행 내역 요약",
      "kind": "table",
      "tables": [
        {
          "title": "집행 금액 요약",
          "headers": ["구분", "금액", "집행률", "비고"],
          "repeat_for": "amount_summary",
          "row_template": ["{{item.label}}", "{{item.amount|money}}", "{{item.ratio_label}}", "{{item.count_label}}"],
          "empty_row": ["-", "-", "-", "-"]
        },
        {
          "title": "항목별 집행 현황 (법정 9개 항목 기준)",
          "headers": ["집행 항목", "집행액 (원)", "건수", "비고"],
          "repeat_for": "category_summaries",
          "row_template": ["{{item.category_name}}", "{{item.amount|money}}", "{{item.count|count}}", "{{item.note}}"],
          "empty_row": ["-", "-", "-", "-"]
        }
      ]
    },
    {
      "section_id": "evidence_validation",
      "title": "3. 증빙 유효성 검증 결과",
      "kind": "table",
      "tables": [
        {
          "headers": ["증빙 유형", "제출", "통과", "오류", "누락", "주요 내용"],
          "repeat_for": "evidence_validation_summaries",
          "row_template": [
            "{{item.evidence_type_name}}",
            "{{item.submitted_count|count}}",
            "{{item.passed_count|count}}",
            "{{item.error_count|count}}",
            "{{item.missing_count|count}}",
            "{{item.major_error}}"
          ],
          "empty_row": ["-", "-", "-", "-", "-", "-"]
        }
      ]
    },
    {
      "section_id": "item_reviews",
      "title": "4. 항목별 적정성 검토 결과",
      "kind": "table",
      "tables": [
        {
          "headers": ["No.", "집행 항목", "집행액", "판정", "요약 사유"],
          "repeat_for": "item_reviews",
          "row_template": [
            "{{item.no}}",
            "{{item.item_name}}",
            "{{item.amount|money}}",
            "{{item.decision_label}}",
            "{{item.summary_reason}}"
          ],
          "empty_row": ["-", "-", "-", "-", "-"]
        }
      ]
    },
    {
      "section_id": "issue_details",
      "title": "5. 부적정 및 검토 필요 상세 내역",
      "kind": "detail",
      "tables": [
        {
          "repeat_for": "issue_details",
          "repeat_mode": "tables",
          "title": "5.{{index}}  {{item.issue_label}} - No.{{item.no}}  {{item.title}}",
          "rows": [
            ["집행 금액", "{{item.amount_label}}"],
            ["{{item.problem_label}}", "{{item.problem_text}}"],
            ["판정 결론", "{{item.decision_label}}"],
            ["법령 근거", "{{item.legal_basis}}"],
            ["조치 사항", "{{item.action_text}}"]
          ],
          "empty_title": "5.1  -",
          "empty_rows": [
            ["확인된 문제", "-"],
            ["법령 근거", "-"],
            ["조치 사항", "-"]
          ]
        }
      ]
    },
    {
      "section_id": "overall_opinion",
      "title": "6. 종합 의견",
      "kind": "opinion",
      "paragraphs": [
        "{{draft.overall_opinion}}",
        "검 토 자 :   {{draft.reviewer_label}}          (서명)  ______________________",
        "검토 일자 :   {{draft.written_date_label}}",
        "{{draft.department_label}}"
      ]
    }
  ]
}
